{
  "name": "helix-graph3-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:client-imports": "npm run build && node scripts/check-client-imports.mjs",
    "check:where-boundaries": "npm run build && node scripts/check-where-boundaries.mjs",
    "gen:bindings": "npm run build && node dist/example/scripts/generate-binding-map.js",
    "gen:views": "npm run build && node dist/example/scripts/generate-compiled-views.js",
    "check:bindings": "npm run build && node dist/example/scripts/generate-binding-map.js --check",
    "check:views": "npm run build && node dist/example/scripts/generate-compiled-views.js --check",
    "verify": "npm run build && node scripts/check-client-imports.mjs && node scripts/check-where-boundaries.mjs && node dist/example/scripts/generate-binding-map.js --check && node dist/example/scripts/generate-compiled-views.js --check && node --test dist/tests",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "start": "node dist/example/server.js",
    "dev": "npm run build && npm run start",
    "dev:watch": "npm run build && NODE_ENV=development node dist/example/server-dev.js",
    "bench": "npm run build && node dist/bench/index.js",
    "bench:ssr": "npm run bench 2>&1 | grep -A 100 'SSR & Resume Performance'",
    "test": "npm run build && node --test dist/tests",
    "test:e2e": "npm run build && npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "mongodb": "^6.21.0"
  }
}
